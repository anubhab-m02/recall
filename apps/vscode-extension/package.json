{
  "name": "@recall/vscode-extension",
  "displayName": "Recall",
  "description": "Personal, local-first developer memory — silent capture, in-context resurfacing, standups, and MCP for AI agents.",
  "version": "0.1.0",
  "publisher": "recall",
  "private": true,
  "type": "module",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "contributes": {
    "commands": [
      {
        "command": "recall.saveAsMemory",
        "title": "Recall: Save as Memory"
      },
      {
        "command": "recall.searchMemory",
        "title": "Recall: Search My Memory"
      },
      {
        "command": "recall.toggleCapturePause",
        "title": "Recall: Pause/Resume Capture"
      },
      {
        "command": "recall.refreshSidebar",
        "title": "Recall: Refresh Memories",
        "icon": "$(refresh)"
      },
      {
        "command": "recall.testRedaction",
        "title": "Recall: Test Redaction"
      },
      {
        "command": "recall.askRecall",
        "title": "Recall: Ask My Memory"
      },
      {
        "command": "recall.showDailyStandup",
        "title": "Recall: Show Daily Standup"
      },
      {
        "command": "recall.showWeeklySummary",
        "title": "Recall: Show Weekly Summary"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "recall",
          "title": "Recall",
          "icon": "media/recall-icon.svg"
        }
      ]
    },
    "views": {
      "recall": [
        {
          "id": "recall.sidebar",
          "name": "Memories"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "recall.refreshSidebar",
          "when": "view == recall.sidebar",
          "group": "navigation"
        },
        {
          "command": "recall.searchMemory",
          "when": "view == recall.sidebar",
          "group": "navigation"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "recall.welcome",
        "title": "Welcome to Recall",
        "description": "Recall quietly captures your debugging process and helps you find it again later — entirely on your machine, encrypted, and pausable any time.",
        "steps": [
          {
            "id": "whatIsCaptured",
            "title": "What Recall captures",
            "description": "File saves, terminal commands, git activity, debug sessions, and diagnostics — turned into a private, searchable memory. File edits are captured as **diffs**, never the full file content.",
            "media": {
              "markdown": "walkthrough/what-is-captured.md"
            }
          },
          {
            "id": "whereStored",
            "title": "Where it's stored",
            "description": "Everything lives locally under `~/.recall/` — nothing leaves your machine unless you explicitly opt in to sync later.",
            "media": {
              "markdown": "walkthrough/where-stored.md"
            }
          },
          {
            "id": "pauseAndRedact",
            "title": "Pause anytime, redact automatically",
            "description": "Click the Recall item in the status bar to pause capture instantly. A redaction pipeline strips likely secrets before anything is saved — try it yourself.\n[Test Redaction](command:recall.testRedaction)",
            "media": {
              "markdown": "walkthrough/pause-and-redact.md"
            }
          }
        ]
      }
    ]
  },
  "dependencies": {
    "@recall/shared-types": "workspace:*",
    "diff": "^9.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
