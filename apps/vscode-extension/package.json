{
  "name": "@recall/vscode-extension",
  "displayName": "Recall",
  "description": "Personal, local-first developer memory — silent capture, in-context resurfacing, standups, and MCP for AI agents.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "contributes": {
    "commands": [
      {
        "command": "recall.saveAsMemory",
        "title": "Recall: Save as Memory"
      },
      {
        "command": "recall.searchMemory",
        "title": "Recall: Search My Memory"
      },
      {
        "command": "recall.toggleCapturePause",
        "title": "Recall: Pause/Resume Capture"
      },
      {
        "command": "recall.refreshSidebar",
        "title": "Recall: Refresh Memories",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "recall",
          "title": "Recall",
          "icon": "media/recall-icon.svg"
        }
      ]
    },
    "views": {
      "recall": [
        {
          "id": "recall.sidebar",
          "name": "Memories"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "recall.refreshSidebar",
          "when": "view == recall.sidebar",
          "group": "navigation"
        },
        {
          "command": "recall.searchMemory",
          "when": "view == recall.sidebar",
          "group": "navigation"
        }
      ]
    }
  },
  "dependencies": {
    "@recall/shared-types": "workspace:*",
    "diff": "^9.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
