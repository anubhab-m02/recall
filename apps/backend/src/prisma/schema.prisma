// Phase 8 stub. Prisma schema against PostgreSQL (spec §9). Every model
// MUST carry a `tenant_id` from day one (spec §6.5), defaulting to a
// personal/single-user tenant in v1 so a future team tier needs no
// historical-data migration. Real models land in Phase 8.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}
